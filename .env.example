# ─── MythosForge API — Environment Configuration ───
# Copy this file to .env and adjust values for your environment.
# All variables are prefixed with MYTHOSFORGE_.

# ── Application ─────────────────────────────────────
MYTHOSFORGE_ENV=dev
MYTHOSFORGE_DEBUG=false

# ── Server ──────────────────────────────────────────
MYTHOSFORGE_HOST=0.0.0.0
MYTHOSFORGE_PORT=8000
MYTHOSFORGE_RELOAD=false
MYTHOSFORGE_WORKERS=1

# ── CORS (comma-separated origins) ─────────────────
# Do NOT use "*" with credentials=true in production
MYTHOSFORGE_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
MYTHOSFORGE_CORS_ALLOW_CREDENTIALS=true

# ── Authentication ─────────────────────────────────
# Set to true to require API key on inference endpoints
MYTHOSFORGE_AUTH_ENABLED=false
# Comma-separated list of valid API keys (generate with: python -c "import secrets; print(f'mf_{secrets.token_urlsafe(32)}')")
# MYTHOSFORGE_API_KEYS=["mf_your_key_here"]

# ── Logging ─────────────────────────────────────────
MYTHOSFORGE_LOG_LEVEL=INFO

# ── Rate Limiting ───────────────────────────────────
MYTHOSFORGE_RATE_LIMIT_PER_MINUTE=60

# ── Inference ───────────────────────────────────────
MYTHOSFORGE_INFERENCE_MAX_TOKENS=512
MYTHOSFORGE_INFERENCE_MAX_LOOPS=32

# ── Observability ───────────────────────────────────
MYTHOSFORGE_METRICS_ENABLED=true
